# Copy this file to `.env` and fill in real values.
# `python-dotenv` loads it automatically when `app.py` starts.

# Required for live news matching (free tier: https://newsapi.org/register).
# Without this key, the backend runs but always returns 0 articles
# (corroboration will always be "unverified").
NEWS_API_KEY=

# Optional. Used for higher-quality claim extraction.
# Without it, a deterministic fallback extractor is used.
OPENAI_API_KEY=

# Optional. Override the Flask port. Defaults to 5000.
# macOS uses 5000 for AirPlay Receiver, so 5050 is a safe default for local dev.
PORT=5050

# Optional. Set to `development` to enable Flask debug mode (auto-reload, tracebacks).
FLASK_ENV=
